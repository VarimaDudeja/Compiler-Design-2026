    IDENTIFIER  shift, and go to state 6
    NUMBER      shift, and go to state 7
    '('         shift, and go to state 8

    expr  go to state 22


state 6

   38 expr: IDENTIFIER .

    $default  reduce using rule 38 (expr)


state 7

   37 expr: NUMBER .

    $default  reduce using rule 37 (expr)


state 8

